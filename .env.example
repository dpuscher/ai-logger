# Optional environment variable overrides (highest priority, for CI / power users).
# These are NOT auto-loaded from a .env file — export them in your shell or CI environment.
# The interactive settings wizard (~/.ai-cache-log/config.json) is used otherwise.

# OPENROUTER_API_KEY=your_openrouter_api_key_here
# API_BASE_URL=https://openrouter.ai/api/v1
# MODEL=z-ai/glm-5
# GEOCACHING_USERNAME=your_username
# GEOCACHING_PASSWORD=your_password
