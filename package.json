  },
  "bugs": {
    "url": "https://github.com/dpuscher/ai-cache-log/issues"
  },
  "homepage": "https://github.com/dpuscher/ai-cache-log#readme",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai",
    "geocache",
    "log",
    "geocaching"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "clipboardy": "^4.0.0",
    "dotenv": "^16.4.7",
    "inquirer": "^12.3.0",
    "openai": "^6.25.0",
    "ora": "^8.1.1",
    "puppeteer": "^23.11.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-block-resources": "^2.4.3",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@lavamoat/allow-scripts": "^3.3.4",
    "@lavamoat/preinstall-always-fail": "^2.1.1",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "whatwg-url": "^13.0.0"
  },
  "bin": "dist/main.js",
  "packageManager": "yarn@4.9.2",
  "lavamoat": {
    "allowScripts": {
      "@biomejs/biome": false,
      "@lavamoat/preinstall-always-fail": false,
      "puppeteer": false,
      "tsx>esbuild": false
    }
  }
