{
  "name": "ai-logger",
  "version": "1.0.1-rc.2",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "tsx src/main.ts",
    "build": "tsc",
    "prepare": "husky && yarn build",
    "start": "node dist/main.js",
    "lint": "biome check --write --unsafe",
    "lint:check": "biome check",
    "setup": "yarn install && yarn allow-scripts"
  },
  "lint-staged": {
    "**/*.{ts,js,json}": [
      "biome check --write --unsafe"
    ]
  },
  "author": "dpuscher",
  "license": "ISC",
  "description": "AI-powered geocaching log generator with multi-provider LLM support",
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dpuscher/ai-logger.git"
  },
  "bugs": {
    "url": "https://github.com/dpuscher/ai-logger/issues"
  },
  "homepage": "https://github.com/dpuscher/ai-logger#readme",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai",
    "geocache",
    "log",
    "geocaching"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "clipboardy": "^5.3.1",
    "inquirer": "^13.3.2",
    "openai": "^6.25.0",
    "ora": "^9.3.0",
    "puppeteer": "24.41.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-block-resources": "^2.4.3",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@lavamoat/allow-scripts": "^4.0.0",
    "@lavamoat/preinstall-always-fail": "^3.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "semantic-release": "^25.0.3",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "whatwg-url": "^13.0.0"
  },
  "bin": "dist/main.js",
  "packageManager": "yarn@4.9.2",
  "lavamoat": {
    "allowScripts": {
      "@biomejs/biome": false,
      "@lavamoat/preinstall-always-fail": false,
      "puppeteer": true,
      "tsx>esbuild": false
    }
  }
}
